{
  "name": "speedmine",
  "version": "1.0.0",
  "description": "マインスイーパ 20×20",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.speedmine.app",
    "productName": "SpeedMine",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html"
    ],
    "win": {
      "target": "portable",
      "icon": null,
      "signAndEditExecutable": false,
      "artifactName": "speedmine.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
